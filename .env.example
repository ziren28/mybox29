# ========================================
# mybox29 — 统一环境变量
# ========================================
# 用法: cp .env.example .env  → 改值 → 加载方式见 README

# ─── 必填: KMS 凭据 ───
# KMS 主密码 (pages.dev 后台密码 / API key)
KMS_API_KEY=

# 这台 master 在 KMS 中的存储 primary 名 (一般 = master session_id 后段)
SECRET_NAME=011UNUTAMv2SxCdhDM4cZfp9


# ─── 选填: 服务端点 (一般不改) ───
KMS_URL=https://kms-admin-4lo.pages.dev
BRIDGE_ENV_ID=env_0148CCLDzQdWNE2cPRThecmr
ORG_ID=f7e0b9c2-5006-402e-87ca-e26147d218ad


# ─── 选填: Worker 路由竞争旋钮 ───
# 默认 (空 / 0) 不抢 master, 仅作 fallback. 必须保持默认才能让 master 持续刷新 OAuth.
# 临时验证 routing 时设为 1 (一键拉爆 priority+epoch).
WORKER_TAKEOVER=0
# 单独控制 (TAKEOVER=0 时生效)
WORKER_PRIORITY=0
WORKER_EPOCH=0


# ─── chat-final.mjs 客户端用 ───
# claude.ai 浏览器 sessionKey cookie (F12 → Application → Cookies)
SESSION_KEY=sk-ant-sid02-...
# 要发消息的目标 session
SESSION_ID=session_xxxxxxxxxxxx
# 默认开启 thinking, 设 0 关闭
THINKING=1
# 单次轮询超时 ms
TIMEOUT_MS=120000
